      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.1xgbplu0u0l5i61913jd10sdry8a].[__tableau_internal_object_id__].[cnt:df_analisis_bi.csv_0088A7C0ACD540169456925EF5CD412D:qk]&quot;' value='Cuenta de certificados' />
          <alias key='&quot;[federated.1xgbplu0u0l5i61913jd10sdry8a].[avg:Calculation_1431074093543424:qk]&quot;' value='Año construcción promedio' />
        </aliases>
      </column>
      <column caption='Media consumo' datatype='real' default-format='n#,##0;-#,##0' name='[Calculation_0692752052609024]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([consumo_global])' />
      </column>
      <column caption='contador climas' datatype='integer' name='[Calculation_0692752053260289]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [provincia], [zona_clima_invierno] : COUNT([id_edificio]) }' />
      </column>
      <column caption='maximo ertificados' datatype='integer' name='[Calculation_0692752053809154]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [provincia] : MAX([Calculation_0692752053260289]) }' />
      </column>
      <column caption='Clima predominante' datatype='string' name='[Calculation_0692752053989379]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{ FIXED [provincia] : MAX(&#13;&#10;    IF [Calculation_0692752053260289] = [Calculation_0692752053809154] &#13;&#10;    THEN [zona_climatica] &#13;&#10;    END&#13;&#10;) }' />
      </column>
      <column caption='compacidad media' datatype='real' name='[Calculation_0692752055025668]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='avg(exp([log_compacidad]))' />
      </column>
      <column caption='Superficie media' datatype='real' name='[Calculation_0692752055320581]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='avg(exp([log_superficie]))' />
      </column>
      <column caption='superficie' datatype='real' name='[Calculation_0692752057126918]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='EXP([log_superficie]) - 1' />
      </column>
      <column caption='Nivel de compacidad' datatype='string' name='[Calculation_0692752057413639]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF exp([log_compacidad]) &lt; 2 THEN &apos;Baja (Unifamiliar aislada)&apos;&#13;&#10;ELSEIF exp([log_compacidad]) &lt;= 5 THEN &apos;Media (Adosados/Bloques pequeños)&apos;&#13;&#10;ELSE &apos;Alta (Grandes bloques/Torres)&apos;&#13;&#10;END' />
      </column>
      <column aggregation='Sum' caption='Tramo de Superficie' datatype='real' name='[Calculation_1048993832615936]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='ROUND([Calculation_0692752057126918] / 10) * 10' />
      </column>
      <column aggregation='Sum' caption='Decada' datatype='integer' name='[Calculation_1431074093543424]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='INT([ano_construccion] / 10) * 10' />
      </column>
      <column caption='Filtro provincia' datatype='boolean' name='[Calculation_1448117103960066]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Parameters].[Parámetro 1] = &quot;Andalucía&quot; THEN TRUE&#13;&#10;ELSE [Parameters].[Parámetro 1] = [provincia]&#13;&#10;END' />
      </column>
      <column caption='df_analisis_bi.csv' datatype='table' name='[__tableau_internal_object_id__].[df_analisis_bi.csv_0088A7C0ACD540169456925EF5CD412D]' role='measure' type='quantitative' />
